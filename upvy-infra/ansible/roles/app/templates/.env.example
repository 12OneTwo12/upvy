# ============================================================
# Ansible에서 자동 배포됨 — 직접 수정하지 마세요
# 변수는 ansible-playbook --extra-vars 로 전달
# ============================================================

# Database (MySQL RDS)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DATABASE=upvy
DB_USERNAME=
DB_PASSWORD=

# Redis (local container)
REDIS_HOST=redis
REDIS_PORT=6379

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AWS S3
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=upvy-images-bucket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# JWT
JWT_SECRET=

# URLs
FRONTEND_URL=https://upvy.org
MOBILE_DEEPLINK_URL=upvy://oauth/callback
MANTICORE_BASE_URL=http://manticore-search:9308
SHARE_BASE_URL=https://api.upvy.org

# Apple OAuth2
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=

# Android
ANDROID_SHA256_FINGERPRINT=

# Email
SMTP_PASSWORD=
