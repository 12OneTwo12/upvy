# Database (MySQL RDS)
MYSQL_HOST={{ mysql_host }}
MYSQL_PORT=3306
MYSQL_DATABASE={{ mysql_database | default('upvy') }}
DB_USERNAME={{ db_username }}
DB_PASSWORD={{ db_password }}

# Redis (local container)
REDIS_HOST=redis
REDIS_PORT=6379

# Google OAuth2
GOOGLE_CLIENT_ID={{ google_client_id }}
GOOGLE_CLIENT_SECRET={{ google_client_secret }}

# AWS S3
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET={{ aws_s3_bucket | default('upvy-images-bucket') }}
AWS_ACCESS_KEY_ID={{ aws_access_key_id }}
AWS_SECRET_ACCESS_KEY={{ aws_secret_access_key }}

# JWT
JWT_SECRET={{ jwt_secret }}

# URLs
FRONTEND_URL={{ frontend_url | default('https://upvy.org') }}
MOBILE_DEEPLINK_URL={{ mobile_deeplink_url | default('upvy://oauth/callback') }}
MANTICORE_BASE_URL=http://manticore-search:9308
SHARE_BASE_URL={{ share_base_url | default('https://api.upvy.org') }}

# Apple OAuth2
APPLE_CLIENT_ID={{ apple_client_id }}
APPLE_CLIENT_SECRET={{ apple_client_secret }}
APPLE_TEAM_ID={{ apple_team_id }}

# Android
ANDROID_SHA256_FINGERPRINT={{ android_sha256_fingerprint | default('PLACEHOLDER_FINGERPRINT') }}

# Email
SMTP_PASSWORD={{ smtp_password }}
