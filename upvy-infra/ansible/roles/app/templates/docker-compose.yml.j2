services:
  nginx:
    image: nginx:1.27-alpine
    ports:
      - "80:80"
    volumes:
      - /opt/upvy/nginx/nginx.conf:/etc/nginx/nginx.conf:ro
    depends_on:
      - upvy-backend
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost/health || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3

  upvy-backend:
    image: upvy/upvy-backend:prod-latest
    env_file: .env
    environment:
      SPRING_APPLICATION_JSON: '{"server.port":8080,"spring.profiles.active":"prod"}'
      JAVA_TOOL_OPTIONS: >-
        -XX:MaxRAMPercentage=75.0
        -XX:+UseG1GC
        -XX:+TieredCompilation
        -XX:TieredStopAtLevel=1
      # --- OTel (주석 해제하여 활성화) ---
      # OTEL_EXPORTER_OTLP_ENDPOINT: http://otel-collector:4317
      # OTEL_SERVICE_NAME: upvy-service
      # OTEL_RESOURCE_ATTRIBUTES: deployment.environment=prod
    # volumes:
    #   - otel-agent:/otel  # OTel 활성화 시 주석 해제
    depends_on:
      redis:
        condition: service_healthy
    restart: unless-stopped
    # health check 제거 — JRE 이미지에 curl/wget 없음
    # Spring Boot는 시작 실패 시 자동 종료 → restart: unless-stopped로 충분
    deploy:
      resources:
        limits:
          memory: 768M

  manticore-search:
    image: upvy/upvy-manticore-search:local
    env_file: .env
    volumes:
      - manticore-data:/var/lib/manticore
      - /opt/upvy/manticore/manticore.conf:/etc/manticoresearch/manticore.conf:ro
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "mysql -h 127.0.0.1 -P 9306 -e 'SHOW STATUS' || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s
    deploy:
      resources:
        limits:
          memory: 512M

  redis:
    image: redis:7-alpine
    command: redis-server --appendonly yes --maxmemory 128mb --maxmemory-policy allkeys-lru
    volumes:
      - redis-data:/data
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 3s
      retries: 5

